{
  "functions": {
    "api/store-doc.js": { "includeFiles": "node_modules/**" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/mail-sync", "schedule": "0 7 * * *" }
  ]
}
